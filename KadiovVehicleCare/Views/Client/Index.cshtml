@model IEnumerable<KadiovVehicleCare.ViewModels.ClientViewModel>

@{
    ViewData["Title"] = "Клиенти";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            @if (User.IsInRole("Admin"))
            {
                <h1 class="fw-bold mb-1">Клиенти</h1>
                <p class="text-muted mb-0">Преглед и управление на клиентски профили.</p>
            }
            else if (User.IsInRole("User"))
            {
                <h1 class="fw-bold mb-1">Моят профил</h1>
                <p class="text-muted mb-0">Преглед и редакция на личния клиентски профил.</p>
            }
        </div>

        @if (ViewBag.CanCreateClient == true)
        {
            <div class="mt-3 mt-md-0">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-dark rounded-3 px-4">Добави клиент</a>
                }
                else if (User.IsInRole("User"))
                {
                    <a asp-action="Create" class="btn btn-dark rounded-3 px-4">Създай профил</a>
                }
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            @if (User.IsInRole("Admin"))
            {
                <form asp-action="Index" method="get" class="mb-4">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-3" placeholder="Търсене по име, фамилия, телефон, имейл" />
                        </div>
                        <div class="col-md-auto">
                            <button type="submit" class="btn btn-primary rounded-3 px-4">Търси</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-3">Изчисти</a>
                        </div>
                    </div>
                </form>
            }

            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Име</th>
                            <th>Фамилия</th>
                            <th>Телефон</th>
                            <th>Имейл</th>
                            <th>Дата на създаване</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>@item.PhoneNumber</td>
                                    <td class="text-muted">@item.Email</td>
                                    <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-3">Детайли</a>

                                        @if (User.IsInRole("Admin") || User.IsInRole("User"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-3">Редакция</a>
                                        }

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-3">Изтриване</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Няма налични записи.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>