@model KadiovVehicleCare.ViewModels.ClientViewModel

@{
    ViewData["Title"] = "Изтриване на клиент";
}

<h1>Изтриване на клиент</h1>

<h4>Сигурни ли сте, че искате да изтриете този клиент?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-3">Име</dt>
        <dd class="col-sm-9">@Model.FirstName</dd>

        <dt class="col-sm-3">Фамилия</dt>
        <dd class="col-sm-9">@Model.LastName</dd>

        <dt class="col-sm-3">Телефон</dt>
        <dd class="col-sm-9">@Model.PhoneNumber</dd>

        <dt class="col-sm-3">Имейл</dt>
        <dd class="col-sm-9">@Model.Email</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Изтрий</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>