@model IEnumerable<KadiovVehicleCare.ViewModels.ServiceViewModel>

@{
    ViewData["Title"] = "Услуги";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Услуги</h1>
            <p class="text-muted mb-0">Преглед и управление на предлаганите автокозметични услуги.</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="mt-3 mt-md-0">
                <a asp-action="Create" class="btn btn-dark rounded-3 px-4">Добави услуга</a>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Име</th>
                            <th>Описание</th>
                            <th>Цена</th>
                            <th>Продължителност</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Name</td>
                                    <td class="text-muted">@item.Description</td>
                                    <td>@item.Price Euro.</td>
                                    <td>@item.DurationInMinutes мин.</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-3">Детайли</a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-3">Редакция</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-3">Изтриване</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Няма налични услуги.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>