@model IEnumerable<KadiovVehicleCare.ViewModels.ServiceViewModel>

@{
    ViewData["Title"] = "Услуги";
}

<h1>Услуги</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добави услуга</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Име</th>
            <th>Описание</th>
            <th>Цена</th>
            <th>Продължителност</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td>@item.DurationInMinutes мин.</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Детайли</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Редакция</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Изтриване</a>
                </td>
            </tr>
        }
    </tbody>
</table>