@model KadiovVehicleCare.ViewModels.EditAppointmentViewModel

@{
    ViewData["Title"] = "Редакция на записване";
}

<h1>Редакция на записване</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3">
            <label asp-for="ClientId" class="form-label"></label>
            <select asp-for="ClientId" asp-items="Model.Clients" class="form-select">
                <option value="">-- Изберете клиент --</option>
            </select>
            <span asp-validation-for="ClientId" class="text-danger"></span>
        </div>
    }
    else if (User.IsInRole("User"))
    {
        <input type="hidden" asp-for="ClientId" />
    }

    <div class="mb-3">
        <label asp-for="CarId" class="form-label"></label>
        <select asp-for="CarId" asp-items="Model.Cars" class="form-select">
            <option value="">-- Изберете автомобил --</option>
        </select>
        <span asp-validation-for="CarId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServiceId" class="form-label"></label>
        <select asp-for="ServiceId" asp-items="Model.Services" class="form-select">
            <option value="">-- Изберете услуга --</option>
        </select>
        <span asp-validation-for="ServiceId" class="text-danger"></span>
    </div>


    <div class="mb-3">
        <label asp-for="AppointmentDate" class="form-label"></label>
        <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
    }
    else if (User.IsInRole("User"))
    {
        <input type="hidden" asp-for="Status" />
    }

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Запази промените</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}