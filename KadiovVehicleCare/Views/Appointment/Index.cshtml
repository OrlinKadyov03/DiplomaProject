@model IEnumerable<KadiovVehicleCare.ViewModels.AppointmentViewModel>

@{
    ViewData["Title"] = "Записвания";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            @if (User.IsInRole("Admin"))
            {
                <h1 class="fw-bold mb-1">Записвания</h1>
                <p class="text-muted mb-0">Преглед и управление на всички записвания в системата.</p>
            }
            else if (User.IsInRole("User"))
            {
                <h1 class="fw-bold mb-1">Моите записвания</h1>
                <p class="text-muted mb-0">Преглед на записванията, създадени от вашия профил.</p>
            }
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-dark rounded-3 px-4">Ново записване</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            @if (User.IsInRole("Admin"))
            {
                <form asp-action="Index" method="get" class="mb-4">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-3" placeholder="Търсене по клиент, автомобил, услуга, статус, бележки" />
                        </div>
                        <div class="col-md-auto">
                            <button type="submit" class="btn btn-primary rounded-3 px-4">Търси</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-3">Изчисти</a>
                        </div>
                    </div>
                </form>
            }

            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Клиент</th>
                            <th>Автомобил</th>
                            <th>Услуга</th>
                            <th>Дата и час</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.ClientFullName</td>
                                    <td>@item.CarInfo</td>
                                    <td>@item.ServiceName</td>
                                    <td>@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Изчакващо</span>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            <span class="badge bg-success rounded-pill px-3 py-2">Завършено</span>
                                        }
                                        else if (item.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2">Отказано</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill px-3 py-2">@item.Status</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-3">Детайли</a>

                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-3">Редакция</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-3">Изтриване</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Няма налични записвания.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>