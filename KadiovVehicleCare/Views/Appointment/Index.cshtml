@model IEnumerable<KadiovVehicleCare.ViewModels.AppointmentViewModel>

@{
    ViewData["Title"] = "Записвания";
}

<h1>Записвания</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добави записване</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Клиент</th>
            <th>Автомобил</th>
            <th>Услуга</th>
            <th>Дата и час</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ClientFullName</td>
                <td>@item.CarInfo</td>
                <td>@item.ServiceName</td>
                <td>@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Детайли</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Редакция</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Изтриване</a>
                </td>
            </tr>
        }
    </tbody>
</table>